{
  "name": "train-eat-track",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "test": "jest",
    "test:unit": "jest --watchAll=false tests/unit",
    "test:coverage": "jest --watchAll=false --coverage tests/unit"
  },
  "jest": {
    "preset": "jest-expo",
    "clearMocks": true,
    "setupFiles": ["./tests/setup.js"],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/$1"
    },
    "transformIgnorePatterns": [
      "node_modules/(?!(?:.pnpm/)?((jest-)?react-native|@react-native(-community)?|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@sentry/react-native|native-base|react-native-svg))"
    ],
    "coverageThreshold": {
      "./src/utils/dateKey.ts": { "branches": 90, "functions": 90, "lines": 90, "statements": 90 },
      "./src/utils/utils.ts": { "branches": 90, "functions": 90, "lines": 90, "statements": 90 },
      "./src/utils/workoutPlanCycle.ts": { "branches": 80, "functions": 90, "lines": 90, "statements": 80 },
      "./src/services/workoutHistoryMemoryCache.ts": { "branches": 90, "functions": 90, "lines": 90, "statements": 90 },
      "./src/services/nutritionCacheService.ts": { "branches": 80, "functions": 90, "lines": 90, "statements": 90 },
      "./src/features/home/homeSelectors.ts": { "branches": 80, "functions": 90, "lines": 90, "statements": 90 }
    }
  },
  "dependencies": {
    "@expo-google-fonts/bebas-neue": "^0.4.1",
    "@expo-google-fonts/inter": "^0.4.2",
    "@expo-google-fonts/jetbrains-mono": "^0.4.1",
    "@expo/vector-icons": "^15.0.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/netinfo": "11.4.1",
    "@react-native-segmented-control/segmented-control": "^2.5.7",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^2.6.3",
    "@react-navigation/native": "^7.1.8",
    "@shopify/flash-list": "2.0.2",
    "@types/jest": "29.5.14",
    "axios": "^1.12.2",
    "expo": "~54.0.13",
    "expo-camera": "~17.0.9",
    "expo-constants": "~18.0.9",
    "expo-document-picker": "~14.0.7",
    "expo-file-system": "~19.0.21",
    "expo-font": "~14.0.9",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.9",
    "expo-image-picker": "~17.0.8",
    "expo-linking": "~8.0.8",
    "expo-router": "~6.0.12",
    "expo-sharing": "~14.0.8",
    "expo-splash-screen": "~31.0.10",
    "expo-status-bar": "~3.0.8",
    "expo-symbols": "~1.0.7",
    "expo-system-ui": "~6.0.7",
    "expo-web-browser": "~15.0.8",
    "firebase": "^12.4.0",
    "jest": "~29.7.0",
    "jest-expo": "~54.0.17",
    "phosphor-react-native": "^3.0.1",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "^0.81.4",
    "react-native-calendars": "^1.1313.0",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-gifted-charts": "^1.4.64",
    "react-native-linear-gradient": "^2.8.3",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "^0.5.1",
    "xlsx": "^0.18.5",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "baseline-browser-mapping": "^2.9.11",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~10.0.0",
    "firebase-admin": "^13.9.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
