rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to check if user owns the document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Helper function to validate user data fields
    function isValidUserData() {
      let data = request.resource.data;
      return data.keys().hasAll(['uid', 'email', 'name']) &&
             data.uid is string &&
             data.email is string &&
             data.name is string &&
             data.name.size() >= 2 &&
             data.name.size() <= 50;
    }

    // Helper function to validate nutrition data
    function isValidNutrition() {
      let data = request.resource.data;
      return data.keys().hasAll(['userID', 'date']) &&
             data.userID is string &&
             data.date is timestamp;
    }

    // Helper function to validate workout data
    function isValidWorkout() {
      let data = request.resource.data;
      return data.keys().hasAll(['userID', 'date']) &&
             data.userID is string &&
             data.date is timestamp;
    }

    // Users collection
    match /users/{userId} {
      // Allow read if authenticated and owner
      allow read: if isOwner(userId);

      // Allow create only if authenticated and creating own document
      allow create: if isOwner(userId) && isValidUserData();

      // Allow update only if authenticated, owner, and not changing uid
      allow update: if isOwner(userId) &&
                       request.resource.data.uid == resource.data.uid &&
                       isValidUserData();

      // Prevent deletion
      allow delete: if false;
    }

    // Nutrition collection
    match /nutrition/{nutritionId} {
      // Allow read if authenticated and owner
      allow read: if isAuthenticated() &&
                     resource.data.userID == request.auth.uid;

      // Allow create if authenticated and data belongs to user
      allow create: if isAuthenticated() &&
                       request.resource.data.userID == request.auth.uid &&
                       isValidNutrition();

      // Allow update if authenticated, owner, and not changing userID
      allow update: if isAuthenticated() &&
                       resource.data.userID == request.auth.uid &&
                       request.resource.data.userID == request.auth.uid &&
                       isValidNutrition();

      // Allow delete if authenticated and owner
      allow delete: if isAuthenticated() &&
                       resource.data.userID == request.auth.uid;
    }

    // Workouts History collection
    match /workoutsHistory/{workoutId} {
      // Allow read if authenticated and owner
      allow read: if isAuthenticated() &&
                     resource.data.userID == request.auth.uid;

      // Allow create if authenticated and data belongs to user
      allow create: if isAuthenticated() &&
                       request.resource.data.userID == request.auth.uid &&
                       isValidWorkout();

      // Allow update if authenticated, owner, and not changing userID
      allow update: if isAuthenticated() &&
                       resource.data.userID == request.auth.uid &&
                       request.resource.data.userID == request.auth.uid &&
                       isValidWorkout();

      // Allow delete if authenticated and owner
      allow delete: if isAuthenticated() &&
                       resource.data.userID == request.auth.uid;
    }

    // Workout Plans collection
    match /workoutPlans/{planId} {
      // Allow read if authenticated and owner
      allow read: if isAuthenticated() &&
                     resource.data.userID == request.auth.uid;

      // Allow create if authenticated and data belongs to user
      allow create: if isAuthenticated() &&
                       request.resource.data.userID == request.auth.uid;

      // Allow update if authenticated, owner, and not changing userID
      allow update: if isAuthenticated() &&
                       resource.data.userID == request.auth.uid &&
                       request.resource.data.userID == request.auth.uid;

      // Allow delete if authenticated and owner
      allow delete: if isAuthenticated() &&
                       resource.data.userID == request.auth.uid;
    }

    // Recent Foods collection
    match /recentFoods/{foodId} {
      // Allow read if authenticated and owner
      allow read: if isAuthenticated() &&
                     resource.data.userID == request.auth.uid;

      // Allow create if authenticated and data belongs to user
      allow create: if isAuthenticated() &&
                       request.resource.data.userID == request.auth.uid;

      // Allow update if authenticated, owner, and not changing userID
      allow update: if isAuthenticated() &&
                       resource.data.userID == request.auth.uid &&
                       request.resource.data.userID == request.auth.uid;

      // Allow delete if authenticated and owner
      allow delete: if isAuthenticated() &&
                       resource.data.userID == request.auth.uid;
    }

    // Water tracking collection (if exists)
    match /water/{waterId} {
      // Allow read if authenticated and owner
      allow read: if isAuthenticated() &&
                     resource.data.userID == request.auth.uid;

      // Allow create if authenticated and data belongs to user
      allow create: if isAuthenticated() &&
                       request.resource.data.userID == request.auth.uid;

      // Allow update if authenticated, owner, and not changing userID
      allow update: if isAuthenticated() &&
                       resource.data.userID == request.auth.uid &&
                       request.resource.data.userID == request.auth.uid;

      // Allow delete if authenticated and owner
      allow delete: if isAuthenticated() &&
                       resource.data.userID == request.auth.uid;
    }

    // Deny all other access by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
